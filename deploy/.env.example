# CodeDebate 环境变量模板
# 复制为 .env 后修改

# GitLab webhook 验证密钥
CODEDEBATE_WEBHOOK_SECRET=your-webhook-secret

# GitLab 个人访问令牌（glab CLI 使用）
GITLAB_TOKEN=your-gitlab-token

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key

# 日志格式: json (默认) | text
# CODEDEBATE_LOG_FORMAT=json

# 日志级别: debug | info (默认) | warn | error
# CODEDEBATE_LOG_LEVEL=info
